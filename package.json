{
  "name": "lebsy-shop",
  "version": "1.0.0",
  "description": "A modern, single-shop e-commerce template built with React 19, Fastify 5, tRPC, and Drizzle ORM. Includes a full template system, admin dashboard, pixel tracking, promo codes, and more.",
  "license": "MIT",
  "author": "Lebsy",
  "private": true,
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx watch --exclude \"./pages/**/*\" --include \"./backend/**/*\" ./server/server.ts",
    "start": "tsx --require ./server/env-preload.cjs ./server/server.ts",
    "build": "unbuild && cross-env NODE_ENV=production vike build",
    "preview": "cross-env NODE_ENV=production tsx ./hono-entry.node.ts",
    "lint": "biome lint --write .",
    "format": "biome format --write .",
    "drizzle:generate": "drizzle-kit generate",
    "drizzle:migrate": "drizzle-kit migrate",
    "drizzle:studio": "drizzle-kit studio",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "seed": "tsx scripts/seed.ts"
  },
  "dependencies": {
    "@fastify/compress": "^8.0.1",
    "@fastify/cookie": "^11.0.2",
    "@fastify/helmet": "^13.0.2",
    "@fastify/middie": "^9.0.3",
    "@fastify/multipart": "^9.0.3",
    "@fastify/postgres": "^6.0.2",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/static": "^8.1.1",
    "@fontsource-variable/roboto-flex": "^5.2.5",
    "@fontsource/poppins": "^5.2.5",
    "@fontsource/roboto": "^5.2.5",
    "@fontsource/rubik": "^5.2.8",
    "@hono/node-server": "^1.13.8",
    "@hookform/resolvers": "^4.1.3",
    "@node-rs/argon2": "^2.0.2",
    "@oslojs/crypto": "^1.0.1",
    "@oslojs/encoding": "^1.1.0",
    "@radix-ui/react-accordion": "^1.2.3",
    "@radix-ui/react-alert-dialog": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.1.4",
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-dropdown-menu": "^2.1.6",
    "@radix-ui/react-label": "^2.1.2",
    "@radix-ui/react-navigation-menu": "^1.2.5",
    "@radix-ui/react-popover": "^1.1.6",
    "@radix-ui/react-radio-group": "^1.3.8",
