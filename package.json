    "fastify": "^5.2.1",
    "fastify-plugin": "^5.0.1",
    "framer-motion": "^12.5.0",
    "hono": "^4.7.4",
    "lucide-react": "^0.477.0",
    "next-themes": "^0.4.6",
    "nodemailer": "^6.10.0",
    "pg": "^8.14.1",
    "pino-pretty": "^13.0.0",
    "react": "^19.0.0",
    "react-day-picker": "8.10.1",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.54.2",
    "react-phone-number-input": "^3.4.12",
    "recharts": "^3.1.2",
