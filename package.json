    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@hono/vite-dev-server": "^0.18.3",
    "@types/node": "^20.17.24",
    "@types/nodemailer": "^6.4.17",
    "@types/react": "^19.0.11",
    "@types/react-dom": "^19.0.4",
    "@types/slug": "^5.0.9",
    "@types/uuid": "^10.0.0",
    "cross-env": "^7.0.3",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vite": "^6.2.2"
  },
  "type": "module",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@biomejs/biome",
      "esbuild",
      "sharp"
    ]
  },
  "imports": {
    "#root/*": "./build/*"
  }
}
