DATABASE_URL=postgresql://postgres:postgres@localhost:5432/lebsy
PUBLIC_ORIGIN=http://localhost:5173
BASE_URL=http://127.0.0.1:3000

# Single Shop Mode
# Set to "true" to disable multi-vendor features and operate as a single shop
# When enabled:
# - Vendor registration is disabled
# - Only admins can access dashboard
# - Vendor-specific routes return 404
# - "Become a vendor" links are hidden
SINGLE_SHOP_MODE=true
VITE_SINGLE_SHOP_MODE=true

# Store branding (optional)
# VITE_STORE_NAME=My Store
# VITE_CURRENCY=EGP

# Store Owner ID (Single-Shop Mode)
# Default vendor/store owner UUID for database FK constraints
# Only needed if you want a custom store ID (optional, has secure default)
# STORE_OWNER_ID=00000000-0000-0000-0000-000000000001

# Email configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# Admin credentials 
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme

# Fincart integration
FINCART_API_URL=https://api-v3.fincart.io
FINCART_API_KEY=your-api-key
FINCART_WEBHOOK_SECRET=your-webhook-secret
FINCART_PICKUP_ID=your-pickup-id
FINCART_MERCHANT_LOCATION=your-merchant-location

# JWT settings
JWT_SECRET=your-jwt-secret-at-least-32-characters-long

# ─── Payment Gateways (Optional) ────────────────────────────────────────────
# Leave blank / remove to use COD-only mode.
# Add keys for any gateway you want to enable — they auto-activate.

# Stripe
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# VITE_STRIPE_PUBLIC_KEY=pk_test_...

# Paymob
# PAYMOB_API_KEY=your-paymob-api-key
# PAYMOB_INTEGRATION_ID=your-integration-id
# PAYMOB_IFRAME_ID=your-iframe-id
# PAYMOB_HMAC_SECRET=your-hmac-secret
